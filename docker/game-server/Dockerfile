FROM node:20.20.2-alpine
WORKDIR /app
COPY game-server/package*.json ./
RUN npm ci
COPY game-server/ ./
COPY shared/ ../shared/


ARG NODE_ENV
ARG PORT
ARG REDIS_URL
ARG SPRING_BOOT_URL
ARG LOGGER_URL
ARG CORS_ORIGINS

ENV NODE_ENV=$NODE_ENV
ENV PORT=$PORT
ENV REDIS_URL=$REDIS_URL
ENV SPRING_BOOT_URL=$SPRING_BOOT_URL
ENV LOGGER_URL=$LOGGER_URL
ENV CORS_ORIGINS=$CORS_ORIGINS

EXPOSE 3001
CMD ["npx", "tsx", "src/index.ts"]
